{
  "groups": [
    {
      "id": "partner_commitments",
      "type": "checkbox",
      "options": [
        { "marker": "Participate in {free_text} Feedback sessions", "trigger": { "field": "partner_feedback_sessions" } },
        { "marker": "Provide case study", "trigger": { "field": "partner_case_study" } },
        { "marker": "Appear as a customer in private customer lists", "trigger": { "field": "partner_private_list" } },
        { "marker": "Appear as a customer on Provider\u2019s website", "trigger": { "field": "partner_public_list" } },
        { "marker": "Serve as a reference", "trigger": { "field": "partner_reference" } },
        { "marker": "{partner_other_details}", "trigger": { "field": "has_partner_other_details" } },
        { "marker": "Give a {discount_amount} discount", "trigger": { "field": "provider_discount" } },
        { "marker": "Develop the following Product functionality", "trigger": { "field": "provider_develop_functionality" } },
        { "marker": "{provider_other_details}", "trigger": { "field": "has_provider_other_details" } }
      ]
    },
    {
      "id": "fee_structure",
      "type": "radio",
      "options": [
        { "marker": "During the Term, Partner will pay Provider", "trigger": { "field": "has_fees", "equals": true } },
        { "marker": "There are no Fees under this Agreement", "trigger": "default" }
      ]
    }
  ]
}
