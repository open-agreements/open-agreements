---
layout: base.njk
pagination:
  data: catalog.previewTemplates
  size: 1
  alias: t
permalink: "templates/{{ t.id }}/index.html"
eleventyComputed:
  title: "{{ t.displayName }} | OpenAgreements"
  description: "{{ t.description }}"
---

    <main class="main-wrap">
      <section class="section template-detail reveal" style="padding: clamp(26px, 4vw, 42px);">
        <p style="margin: 0 0 16px;"><a href="/templates" style="color: var(--accent-deep); text-decoration: none; font-size: 0.88rem;">&larr; Back to catalog</a></p>

        <h1 style="font-size: clamp(1.4rem, 3.5vw, 2.2rem); max-width: none;">{{ t.displayName }}</h1>

        <div class="template-meta" style="margin: 12px 0;">
          <span class="template-badge-oa">OpenAgreements original</span>
          <span class="template-license">{{ t.license }}</span>
        </div>

        <p style="color: var(--ink-soft); max-width: 65ch;">{{ t.description }}</p>

        <p class="template-fields" style="margin: 12px 0 24px;">{{ t.totalFields }} total field{{ "s" if t.totalFields != 1 }}</p>

        <div class="template-detail-actions" style="margin-bottom: 24px;">
          {% if t.hasDocxDownload %}
          <a class="btn btn-ghost" href="/downloads/{{ t.id }}.docx" download>Download blank DOCX</a>
          {% endif %}
          {% if t.hasMarkdownDownload %}
          <a class="btn btn-ghost" href="/downloads/{{ t.id }}.md" download>Download markdown</a>
          {% endif %}
          <a class="btn btn-primary" href="/?template={{ t.id }}#start">Installation instructions</a>
        </div>

        {% if t.fields and t.fields.length %}
        <h2 style="font-size: 1.2rem; margin: 32px 0 12px;">Fields</h2>
        <div style="overflow-x: auto;">
          <table class="fields-table" style="width: 100%; border-collapse: collapse; font-size: 0.88rem;">
            <thead>
              <tr style="border-bottom: 2px solid var(--border, #e0e0e0); text-align: left;">
                <th style="padding: 8px 12px;">Field</th>
                <th style="padding: 8px 12px;">Type</th>
                <th style="padding: 8px 12px;">Default</th>
                <th style="padding: 8px 12px;">Description</th>
                {% if t.hasRationale %}<th style="padding: 8px 12px;">Default Rationale</th>{% endif %}
              </tr>
            </thead>
            <tbody>
              {%- for field in t.fields %}
              <tr style="border-bottom: 1px solid var(--border, #e8e8e8);">
                <td style="padding: 8px 12px; font-family: monospace; white-space: nowrap;">{{ field.name }}</td>
                <td style="padding: 8px 12px;">{{ field.type }}</td>
                <td style="padding: 8px 12px;">{% if field.default %}{{ field.default }}{% else %}<span style="color: var(--ink-soft);">&mdash;</span>{% endif %}</td>
                <td style="padding: 8px 12px;">{{ field.description }}</td>
                {% if t.hasRationale %}<td style="padding: 8px 12px; font-size: 0.82rem; color: var(--ink-soft);">{% if field.defaultValueRationale %}{{ field.defaultValueRationale }}{% endif %}</td>{% endif %}
              </tr>
              {%- endfor %}
            </tbody>
          </table>
        </div>
        {% endif %}

        {% if t.marketDataCitations and t.marketDataCitations.length %}
        <div style="margin-top: 24px; padding: 16px; background: var(--bg-soft, #f8f8f8); border-radius: 8px; font-size: 0.84rem;">
          <p style="margin: 0 0 8px; font-weight: 600;">Sources</p>
          <p style="margin: 0 0 8px; color: var(--ink-soft);">Default values are informed by market data from the following published venture financing reports. These sources provide statistical data only &mdash; all template forms are from the NVCA Model Legal Documents.</p>
          <ul style="margin: 0; padding-left: 20px;">
            {%- for cite in t.marketDataCitations %}
            <li>{% if cite.url %}<a href="{{ cite.url }}" style="color: var(--accent-deep);">{{ cite.label }}</a>{% else %}{{ cite.label }}{% endif %}</li>
            {%- endfor %}
          </ul>
        </div>
        {% endif %}

        {% if t.previewPages and t.previewPages.length %}
        <div class="template-preview">
          {%- for page in t.previewPages %}
          <img
            class="template-preview-page"
            src="{{ page }}"
            alt="{{ t.displayName }} — page {{ loop.index }}"
            loading="{% if loop.first %}eager{% else %}lazy{% endif %}"
          />
          {%- endfor %}
        </div>
        {% endif %}
      </section>
    </main>
